---
import Layout from "../layouts/Layout.astro";

const heroImage =
  "/images/805a1137.jpg";

const galleryImages = [
  "/images/img_0865.jpg",
  "/images/about-abbie.jpg",
  "/images/805a0763.jpg",
  "/images/805a0333.jpg",
  "/images/805a1137.jpg",
  "/images/805a0961.jpg",
];
---

<Layout title="Gallery" description="Browse family, lifestyle, and milestone photography sessions by Abigail Marie Photography in Schertz, TX.">
  <section class="page-hero">
    <img src={heroImage} alt="Gallery hero" class="hero-image" />
    <div class="hero-overlay"></div>
    <div class="hero-content">
      <p class="eyebrow">Portfolio</p>
      <h1>Gallery</h1>
    </div>
  </section>

  <section class="gallery-section">
    <div class="container">
      <div class="masonry reveal">
        {
          galleryImages.map((src, i) => (
            <figure>
              <img src={src} alt={`Abigail Marie Photography portfolio image ${i + 1}`} loading="lazy" />
            </figure>
          ))
        }
      </div>
      <div class="cta-row reveal">
        <a href="/packages" class="btn btn-rose">Book a Session</a>
      </div>
    </div>
  </section>
</Layout>
