---
import Layout from "../layouts/Layout.astro";

const heroImage =
  "https://images.squarespace-cdn.com/content/v1/6331dd9e1b69b852b3d1091a/fdd98849-61ab-4f5e-8b52-799b86f9fe1f/805A1137.jpg";

const galleryImages = [
  "https://images.squarespace-cdn.com/content/v1/6331dd9e1b69b852b3d1091a/02d1513a-74e7-4bf0-afef-2f11e14c557e/IMG_0865.jpg",
  "https://images.squarespace-cdn.com/content/v1/6331dd9e1b69b852b3d1091a/f129ae52-cd5d-4bfa-90a5-b04d95f1c65e/Luke-San-Antonio-Photographer40.jpg",
  "https://images.squarespace-cdn.com/content/v1/6331dd9e1b69b852b3d1091a/8bea8244-09a5-4d72-898b-35c4bcbc950c/805A0763.jpg",
  "https://images.squarespace-cdn.com/content/v1/6331dd9e1b69b852b3d1091a/b42d2a93-c92e-45e9-8d66-620f0ec42673/805A0333.JPG",
  "https://images.squarespace-cdn.com/content/v1/6331dd9e1b69b852b3d1091a/fdd98849-61ab-4f5e-8b52-799b86f9fe1f/805A1137.jpg",
  "https://images.squarespace-cdn.com/content/v1/6331dd9e1b69b852b3d1091a/e604a33d-3bd7-4244-9e23-44de12af639b/805A0961.jpg",
];
---

<Layout title="Gallery" description="Browse family, lifestyle, and milestone photography sessions by Abigail Marie Photography in Schertz, TX.">
  <section class="page-hero">
    <img src={heroImage} alt="Gallery hero" class="hero-image" />
    <div class="hero-overlay"></div>
    <div class="hero-content">
      <p class="eyebrow">Portfolio</p>
      <h1>Gallery</h1>
    </div>
  </section>

  <section class="gallery-section">
    <div class="container">
      <div class="masonry reveal">
        {
          galleryImages.map((src, i) => (
            <figure>
              <img src={src} alt={`Abigail Marie Photography portfolio image ${i + 1}`} loading="lazy" />
            </figure>
          ))
        }
      </div>
      <div class="cta-row reveal">
        <a href="/packages" class="btn btn-rose">Book a Session</a>
      </div>
    </div>
  </section>
</Layout>
